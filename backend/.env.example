# Copy to .env and adjust.
# Postgres connection (matches docker-compose.yml, host port 5433).
ANALYZER_DATABASE_URL=postgresql+psycopg://analyzer:analyzer@localhost:5433/analyzer

# Storage backend: "local" now; "s3" is a future drop-in.
ANALYZER_STORAGE_BACKEND=local
ANALYZER_STORAGE_LOCAL_DIR=./data/uploads

# CORS origins for the frontend dev server.
ANALYZER_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Feature flag — natural-language search is stubbed off for now.
ANALYZER_ENABLE_NL_SEARCH=false
